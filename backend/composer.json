{
    "name": "autothreads/backend",
    "description": "AutoThreads - AI-Powered Threads Affiliate Content Automation",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "illuminate/database": "^11.0",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5",
        "predis/predis": "^2.2",
        "guzzlehttp/guzzle": "^7.8",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "AutoThreads\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AutoThreads\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php",
        "serve": "php -S localhost:8080 -t public",
        "worker": "php src/Queue/worker.php"
    }
}
