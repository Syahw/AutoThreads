# Application
APP_NAME=AutoThreads
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_KEY=

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=autothreads
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.8

# Threads API
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=
THREADS_API_VERSION=v1.0

# JWT Authentication
JWT_SECRET=
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# Scheduler
SCHEDULER_MIN_POSTS_PER_DAY=1
SCHEDULER_MAX_POSTS_PER_DAY=5
SCHEDULER_EARLIEST_HOUR=8
SCHEDULER_LATEST_HOUR=22
SCHEDULER_TIMEZONE=UTC

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_HOUR=30

# Logging
LOG_LEVEL=info
LOG_CHANNEL=file
