# Application
APP_NAME=AutoThreads

# Optional: absolute path to CA bundle (fixes cURL 60 on WAMP if php.ini alone fails)
# SSL_CAFILE=c:/wamp64/www/AutoThreads/backend/cacert.pem
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_KEY=

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=autothreads
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.8

# Threads API (use Threads app ID/secret from Meta dashboard, not Facebook app)
THREADS_APP_ID=
THREADS_APP_SECRET=
# REQUIRED: HTTPS only — Meta error 1349187 blocks http:// redirect URIs.
# Easiest local setup: run `ngrok http 80` then use (replace subdomain):
# THREADS_REDIRECT_URI=https://YOUR_SUBDOMAIN.ngrok-free.app/AutoThreads/backend/public/api/v1/threads/callback
# Add the same URL in Meta app → OAuth redirect URLs.
THREADS_REDIRECT_URI=
THREADS_API_VERSION=v1.0
THREADS_PUBLISH_DELAY_SECONDS=5
THREADS_AFTER_PUBLISH_DELAY_SECONDS=3
THREADS_MAX_TEXT_LENGTH=500
# Where to send the user after OAuth (can stay http://localhost for Vite)
FRONTEND_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# Scheduler
SCHEDULER_MIN_POSTS_PER_DAY=1
SCHEDULER_MAX_POSTS_PER_DAY=5
# 0–23 = full day (includes 12:00 AM–11:59 PM)
SCHEDULER_EARLIEST_HOUR=0
SCHEDULER_LATEST_HOUR=23
# IANA timezone for schedule picker & cron (e.g. Asia/Kuala_Lumpur)
SCHEDULER_TIMEZONE=UTC

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_HOUR=30

# Logging
LOG_LEVEL=info
LOG_CHANNEL=file
